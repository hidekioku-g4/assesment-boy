DEEPGRAM_API_KEY=dg_your_api_key_here
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# TTS Provider: cartesia / google
TTS_PROVIDER=cartesia
TTS_FALLBACK=google
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
# Google TTS settings (used when TTS_PROVIDER=google)
TTS_VOICE_NAME=ja-JP-Neural2-B
TTS_LANGUAGE_CODE=ja-JP
TTS_AUDIO_ENCODING=MP3
TTS_SPEAKING_RATE=1
TTS_PITCH=0
TTS_MAX_CHARS=1200
# Gemini retry/timeout
GEMINI_TIMEOUT_MS=60000
GEMINI_RETRIES=2
GEMINI_RETRY_BASE_MS=800
GEMINI_RETRY_MAX_MS=5000
PORT=37211
GOOGLE_APPLICATION_CREDENTIALS=
GCP_WIF_CREDENTIALS=
GCP_WIF_SUBJECT_TOKEN_FILE=
BQ_PROJECT_ID=
BQ_DATASET=
BQ_FACILITATOR_PROJECT_ID=
BQ_FACILITATOR_DATASET=
BQ_FACILITATOR_TABLE=
BQ_TALENT_PROJECT_ID=
BQ_TALENT_DATASET=
BQ_TALENT_TABLE=
BQ_FACILITATOR_ID_COLUMN=id
BQ_FACILITATOR_NAME_COLUMN=name
BQ_FACILITATOR_KANA_COLUMN=name_kana
BQ_FACILITATOR_EXTRA_COLUMNS=email,department
BQ_FACILITATOR_SEARCH_COLUMNS=name,name_kana,email
BQ_TALENT_ID_COLUMN=id
BQ_TALENT_NAME_COLUMN=name
BQ_TALENT_KANA_COLUMN=name_kana
BQ_TALENT_EXTRA_COLUMNS=email,department
BQ_TALENT_SEARCH_COLUMNS=name,name_kana,email
BQ_EXPORT_PROJECT_ID=
BQ_EXPORT_DATASET=
BQ_EXPORT_TABLE=
# Session summary BigQuery settings
BQ_SUMMARY_PROJECT_ID=tl-datamanagement-prod
BQ_SUMMARY_DATASET=talent_log
BQ_SUMMARY_TABLE=session_summaries
# User profile (meta-summary) table
BQ_PROFILE_TABLE=user_profiles
# メタ要約を更新する間隔（何セッションごとか）
META_SUMMARY_UPDATE_INTERVAL=3
# 議題テーブル
BQ_TOPICS_TABLE=suggested_topics
BQ_MAX_LIMIT=2000
BQ_CACHE_TTL_MS=300000
# Data retention (default true: no local/server persistence)
NO_RETENTION_MODE=true
# BigQuery insert retry tuning
BQ_INSERT_RETRIES=2
BQ_INSERT_RETRY_BASE_MS=500
BQ_INSERT_RETRY_MAX_MS=4000

